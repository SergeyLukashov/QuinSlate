<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Jott.Ui.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Jott.Ui"
    xmlns:views="using:Jott.Ui.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="JottMainWindow">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Padding="4">
            <Button x:Name="PinButton" Content="📌" Click="OnPinButtonClicked"
                    Width="32" Height="32" Padding="0"
                    ToolTipService.ToolTip="Pin window" />
        </StackPanel>

        <views:BufferPanel x:Name="Panel" Grid.Row="1" />
    </Grid>
</Window>

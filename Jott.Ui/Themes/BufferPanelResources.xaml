<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <x:Double x:Key="TitleBarRowHeight">32</x:Double>
    <x:Double x:Key="TitleBarButtonWidth">40</x:Double>
    <!-- The pin and close buttons are a top-level OVERLAY at the window's top-right
         corner (see the StackPanel in RootGrid in BufferPanel.xaml). A top-level overlay
         can never be clipped by the TabView's internal columns, which is why the two
         earlier footer-hosted approaches failed.

         To keep the tabs from sliding under those overlay buttons, the TabStripFooter
         holds a fixed-width transparent spacer of exactly TitleBarButtonsClusterWidth.
         A fixed footer width makes the SDK pin RightContentColumn.MinWidth to a stable
         value (no star-column collapse), so the tabs always stop where the buttons
         begin.

         Left gap between the tab strip's right edge (or the scroll-forward button in
         overflow mode) and the pin button's left edge. -->
    <Thickness x:Key="TitleBarFooterLeftGap">12,0,0,0</Thickness>
    <!-- Total width occupied by the overlay button cluster, and therefore the width
         the footer spacer must reserve so the reserved strip region and the overlay
         line up exactly. = Pin 40 + Close 40 (both TitleBarButtonWidth) + left gap 12
         (TitleBarFooterLeftGap) + right inset 0 = 92. With this the tab right edge lands
         at window-92 and the pin left edge at window-80, giving the consistent 12px gap,
         and the close button sits flush against the window's right edge.

         IMPORTANT: the space is reserved EXACTLY ONCE, by the TabStripFooter spacer
         (its Auto column pins RightContentColumn.MinWidth). The TabView's right Padding
         must stay 0 (TabViewTabStripRightPadding) — Padding is applied to the whole
         strip container and the footer is a separate column INSIDE it, so a non-zero
         right Padding would stack on top of the footer and double-reserve. -->
    <x:Double x:Key="TitleBarButtonsClusterWidth">92</x:Double>
    <!-- The footer spacer alone reserves the cluster width, so the strip needs no extra
         right padding. Keep this zero to avoid double-reserving (see note above). -->
    <Thickness x:Key="TabViewTabStripRightPadding">0,0,0,0</Thickness>
    <SolidColorBrush x:Key="SystemAccentColorBrush" Color="{ThemeResource SystemAccentColor}" />

    <Duration x:Key="HoverIndicatorAnimationDuration">0:0:0.2</Duration>
    <Duration x:Key="ActiveIndicatorAnimationDuration">0:0:0.3</Duration>

    <Style TargetType="TabViewItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <!-- No outer margin: the SDK's equal-mode overflow test counts only
             tabWidth*count, NOT the item margin, so an outer margin makes the laid-out
             strip wider than the SDK thinks and spuriously trips the scroll buttons even
             when the tabs fill exactly. The inter-tab gap is instead applied INSIDE the
             tab, on the TabBackground pill's leading edge (see its Margin below), so it
             is part of the measured tab width. Carrying the gap on the LEFT means no tab
             ever has a trailing margin: whichever tab is rightmost-visible always abuts
             the right scroll button, keeping the strip symmetric in overflow mode. -->

        <Setter Property="Margin" Value="0,1,0,0" />
        <Setter Property="Padding" Value="3,0,3,0" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabViewItem">
                    <Grid x:Name="LayoutRoot" Background="Transparent" Height="32">
                        <!-- Rounded floating tab background pill -->
                        <Border x:Name="TabBackground"
                                Height="26"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top"
                                Margin="6,3,0,0">
                            <Grid>
                                <!-- Header content (Emoji, title, edit button) -->
                                <ContentPresenter x:Name="ContentPresenter"
                                                  Content="{TemplateBinding Header}"
                                                  ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  Margin="{TemplateBinding Padding}"
                                                  FontWeight="Normal">
                                    <ContentPresenter.Foreground>
                                        <SolidColorBrush x:Name="TextForegroundBrush" Color="{ThemeResource TabViewItemHeaderForegroundColor}" />
                                    </ContentPresenter.Foreground>
                                </ContentPresenter>
                            </Grid>
                        </Border>

                        <!-- Indication bar under active tab, perfectly aligned at bottom of row.
                             The grid is inset by the same left margin (6) as the TabBackground
                             pill so its bounds match the visible tab exactly; this keeps the
                             5%/90%/5% column split tracking the pill rather than the full row. -->
                        <Grid VerticalAlignment="Bottom" Height="2" Margin="6,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5*" />
                                <ColumnDefinition Width="90*" />
                                <ColumnDefinition Width="5*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="ActiveIndicator"
                                    Grid.Column="1"
                                    Height="2"
                                    CornerRadius="1"
                                    Opacity="0"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.Background>
                                    <SolidColorBrush x:Name="ActiveIndicatorBrush" Color="{ThemeResource SystemAccentColor}" />
                                </Border.Background>
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="ActiveIndicatorScale" ScaleX="0" />
                                </Border.RenderTransform>
                            </Border>
                        </Grid>

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ActiveIndicator"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="{StaticResource HoverIndicatorAnimationDuration}">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ActiveIndicatorScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0"
                                                         Duration="{StaticResource HoverIndicatorAnimationDuration}">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <ColorAnimation Storyboard.TargetName="ActiveIndicatorBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="{ThemeResource TabViewItemHeaderHoverIndicatorColor}"
                                                        Duration="{StaticResource HoverIndicatorAnimationDuration}">
                                            <ColorAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                        <ColorAnimation Storyboard.TargetName="TextForegroundBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="{ThemeResource TabViewItemHeaderForegroundColor}"
                                                        Duration="{StaticResource HoverIndicatorAnimationDuration}">
                                            <ColorAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                    <VisualState.Setters>
                                        <Setter Target="TabBackground.Background" Value="Transparent" />
                                        <Setter Target="ContentPresenter.FontWeight" Value="Normal" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ActiveIndicator"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="{StaticResource HoverIndicatorAnimationDuration}">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ActiveIndicatorScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.6"
                                                         Duration="{StaticResource HoverIndicatorAnimationDuration}">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <ColorAnimation Storyboard.TargetName="ActiveIndicatorBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="{ThemeResource TabViewItemHeaderHoverIndicatorColor}"
                                                        Duration="{StaticResource HoverIndicatorAnimationDuration}">
                                            <ColorAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                        <ColorAnimation Storyboard.TargetName="TextForegroundBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="{ThemeResource TabViewItemHeaderForegroundColor}"
                                                        Duration="{StaticResource HoverIndicatorAnimationDuration}">
                                            <ColorAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                    <VisualState.Setters>
                                        <Setter Target="TabBackground.Background" Value="Transparent" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ActiveIndicator"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ActiveIndicatorScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <ColorAnimation Storyboard.TargetName="ActiveIndicatorBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="{ThemeResource SystemAccentColor}"
                                                        Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                            <ColorAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                        <ColorAnimation Storyboard.TargetName="TextForegroundBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="{ThemeResource TabViewItemHeaderForegroundSelectedColor}"
                                                        Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                            <ColorAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                    <VisualState.Setters>
                                        <Setter Target="TabBackground.Background" Value="Transparent" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Selected">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ActiveIndicator"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ActiveIndicatorScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <ColorAnimation Storyboard.TargetName="ActiveIndicatorBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="{ThemeResource SystemAccentColor}"
                                                        Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                            <ColorAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                        <ColorAnimation Storyboard.TargetName="TextForegroundBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="{ThemeResource TabViewItemHeaderForegroundSelectedColor}"
                                                        Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                            <ColorAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                    <VisualState.Setters>
                                        <Setter Target="TabBackground.Background" Value="Transparent" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="PointerOverSelected">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ActiveIndicator"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ActiveIndicatorScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <ColorAnimation Storyboard.TargetName="ActiveIndicatorBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="{ThemeResource SystemAccentColor}"
                                                        Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                            <ColorAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                        <ColorAnimation Storyboard.TargetName="TextForegroundBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="{ThemeResource TabViewItemHeaderForegroundSelectedColor}"
                                                        Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                            <ColorAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                    <VisualState.Setters>
                                        <Setter Target="TabBackground.Background" Value="Transparent" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="PressedSelected">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ActiveIndicator"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ActiveIndicatorScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <ColorAnimation Storyboard.TargetName="ActiveIndicatorBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="{ThemeResource SystemAccentColor}"
                                                        Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                            <ColorAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                        <ColorAnimation Storyboard.TargetName="TextForegroundBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="{ThemeResource TabViewItemHeaderForegroundSelectedColor}"
                                                        Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                            <ColorAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                    <VisualState.Setters>
                                        <Setter Target="TabBackground.Background" Value="Transparent" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="DisabledStates">
                                <VisualState x:Name="Enabled" />
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="LayoutRoot.Opacity" Value="0.5" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TitleBarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Width" Value="{StaticResource TitleBarButtonWidth}" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="RootGrid" Background="Transparent" CornerRadius="0">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource TitleBarButtonBackgroundPointerOver}" />
                                        <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TitleBarButtonForegroundPointerOver}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource TitleBarButtonBackgroundPressed}" />
                                        <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TitleBarButtonForegroundPressed}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Opacity" Value="0.5" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <ContentPresenter x:Name="ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CloseTitleBarButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="RootGrid" Background="Transparent" CornerRadius="0">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource CloseButtonBackgroundPointerOver}" />
                                        <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource CloseButtonForegroundPointerOver}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource CloseButtonBackgroundPressed}" />
                                        <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource CloseButtonForegroundPressed}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Opacity" Value="0.5" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <ContentPresenter x:Name="ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
            <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="Transparent" />
            <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
            <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="Transparent" />
            <SolidColorBrush x:Key="TitleBarButtonBackgroundPointerOver" Color="#363636" />
            <SolidColorBrush x:Key="TitleBarButtonBackgroundPressed" Color="#30FFFFFF" />
            <SolidColorBrush x:Key="TitleBarButtonForegroundPointerOver" Color="White" />
            <SolidColorBrush x:Key="TitleBarButtonForegroundPressed" Color="White" />
            <SolidColorBrush x:Key="CloseButtonBackgroundPointerOver" Color="#C42B1C" />
            <SolidColorBrush x:Key="CloseButtonBackgroundPressed" Color="#B0271A" />
            <SolidColorBrush x:Key="CloseButtonForegroundPointerOver" Color="White" />
            <SolidColorBrush x:Key="CloseButtonForegroundPressed" Color="White" />
            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundInactive" Color="#0FFFFFFF" />
            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundInactivePointerOver" Color="#22FFFFFF" />
            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelected" Color="#22FFFFFF" />
            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundPressed" Color="#22FFFFFF" />
            <Color x:Key="TabViewItemHeaderForegroundColor">#99FFFFFF</Color>
            <Color x:Key="TabViewItemHeaderForegroundPointerOverColor">#E6FFFFFF</Color>
            <Color x:Key="TabViewItemHeaderForegroundPressedColor">#E6FFFFFF</Color>
            <Color x:Key="TabViewItemHeaderForegroundSelectedColor">White</Color>
            <SolidColorBrush x:Key="TabViewItemHeaderForeground" Color="{ThemeResource TabViewItemHeaderForegroundColor}" />
            <SolidColorBrush x:Key="TabViewItemHeaderForegroundPointerOver" Color="{ThemeResource TabViewItemHeaderForegroundPointerOverColor}" />
            <SolidColorBrush x:Key="TabViewItemHeaderForegroundPressed" Color="{ThemeResource TabViewItemHeaderForegroundPressedColor}" />
            <SolidColorBrush x:Key="TabViewItemHeaderForegroundSelected" Color="{ThemeResource TabViewItemHeaderForegroundSelectedColor}" />
            <Color x:Key="TabViewItemHeaderHoverIndicatorColor">#55FFFFFF</Color>
            <SolidColorBrush x:Key="TabViewItemHeaderHoverIndicatorBrush" Color="{ThemeResource TabViewItemHeaderHoverIndicatorColor}" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
            <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="Transparent" />
            <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
            <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="Transparent" />
            <SolidColorBrush x:Key="TitleBarButtonBackgroundPointerOver" Color="#10000000" />
            <SolidColorBrush x:Key="TitleBarButtonBackgroundPressed" Color="#20000000" />
            <SolidColorBrush x:Key="TitleBarButtonForegroundPointerOver" Color="Black" />
            <SolidColorBrush x:Key="TitleBarButtonForegroundPressed" Color="Black" />
            <SolidColorBrush x:Key="CloseButtonBackgroundPointerOver" Color="#C42B1C" />
            <SolidColorBrush x:Key="CloseButtonBackgroundPressed" Color="#B0271A" />
            <SolidColorBrush x:Key="CloseButtonForegroundPointerOver" Color="White" />
            <SolidColorBrush x:Key="CloseButtonForegroundPressed" Color="White" />
            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundInactive" Color="#0F000000" />
            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundInactivePointerOver" Color="#22000000" />
            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelected" Color="#22000000" />
            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundPressed" Color="#22000000" />
            <Color x:Key="TabViewItemHeaderForegroundColor">#66000000</Color>
            <Color x:Key="TabViewItemHeaderForegroundPointerOverColor">#E6000000</Color>
            <Color x:Key="TabViewItemHeaderForegroundPressedColor">#E6000000</Color>
            <Color x:Key="TabViewItemHeaderForegroundSelectedColor">Black</Color>
            <SolidColorBrush x:Key="TabViewItemHeaderForeground" Color="{ThemeResource TabViewItemHeaderForegroundColor}" />
            <SolidColorBrush x:Key="TabViewItemHeaderForegroundPointerOver" Color="{ThemeResource TabViewItemHeaderForegroundPointerOverColor}" />
            <SolidColorBrush x:Key="TabViewItemHeaderForegroundPressed" Color="{ThemeResource TabViewItemHeaderForegroundPressedColor}" />
            <SolidColorBrush x:Key="TabViewItemHeaderForegroundSelected" Color="{ThemeResource TabViewItemHeaderForegroundSelectedColor}" />
            <Color x:Key="TabViewItemHeaderHoverIndicatorColor">#55000000</Color>
            <SolidColorBrush x:Key="TabViewItemHeaderHoverIndicatorBrush" Color="{ThemeResource TabViewItemHeaderHoverIndicatorColor}" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
            <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="Transparent" />
            <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
            <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="Transparent" />
            <SolidColorBrush x:Key="TitleBarButtonBackgroundPointerOver" Color="#363636" />
            <SolidColorBrush x:Key="TitleBarButtonBackgroundPressed" Color="#30FFFFFF" />
            <SolidColorBrush x:Key="TitleBarButtonForegroundPointerOver" Color="White" />
            <SolidColorBrush x:Key="TitleBarButtonForegroundPressed" Color="White" />

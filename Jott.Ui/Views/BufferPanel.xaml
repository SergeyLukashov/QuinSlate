<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Jott.Ui.Views.BufferPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Jott.Ui.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <!--
                Standard Windows title bar height is 32 px. We align the TabView's
                tab strip and all custom title-bar controls (icon, pin button) to
                this height so they share the same vertical center as the
                OS-drawn system caption buttons (min / max / close).
            -->
            <x:Double x:Key="TitleBarRowHeight">32</x:Double>
            <x:Double x:Key="TabViewItemHeaderMinHeight">32</x:Double>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="Transparent" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="Transparent" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="Transparent" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="Transparent" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Background="Transparent">
        <TabView
            x:Name="BufferTabView"
            IsAddTabButtonVisible="False"
            CanReorderTabs="True"
            TabWidthMode="Equal"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch">

            <TabView.TabStripHeader>
                <Border
                    x:Name="TitleBarIconDragArea"
                    Padding="10,0,10,0"
                    Height="{StaticResource TitleBarRowHeight}"
                    VerticalAlignment="Top"
                    Background="Transparent">
                    <Image
                        Source="ms-appx:///Assets/Square44x44Logo.scale-200.png"
                        Width="16"
                        Height="16"
                        VerticalAlignment="Center"
                        ToolTipService.ToolTip="Jott" />
                </Border>
            </TabView.TabStripHeader>

            <TabView.TabStripFooter>
                <Grid
                    Height="{StaticResource TitleBarRowHeight}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top">
                    <Grid
                        x:Name="TitleBarDragGrid"
                        Background="Transparent"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch" />
                    <StackPanel
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                        <Button
                            x:Name="PinButton"
                            Width="{StaticResource TitleBarRowHeight}"
                            Height="{StaticResource TitleBarRowHeight}"
                            Padding="0"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            ToolTipService.ToolTip="Pin window"
                            Click="OnPinButtonClicked">
                            <FontIcon
                                x:Name="PinIcon"
                                Glyph="&#xE718;"
                                FontSize="12" />
                        </Button>
                        <Border
                            x:Name="SystemCloseButtonSpacer"
                            Width="0"
                            VerticalAlignment="Stretch" />
                    </StackPanel>
                </Grid>
            </TabView.TabStripFooter>

        </TabView>
    </Grid>
</UserControl>

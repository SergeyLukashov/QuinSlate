<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Jott.Ui.Views.BufferPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Jott.Ui.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <x:Double x:Key="TitleBarRowHeight">32</x:Double>
            <x:Double x:Key="TitleBarButtonWidth">40</x:Double>
            <!-- The pin and close buttons are a top-level OVERLAY at the window's top-right
                 corner (see the StackPanel in RootGrid below). A top-level overlay can never
                 be clipped by the TabView's internal columns, which is why the two earlier
                 footer-hosted approaches failed.

                 To keep the tabs from sliding under those overlay buttons, the TabStripFooter
                 holds a fixed-width transparent spacer of exactly TitleBarButtonsClusterWidth.
                 A fixed footer width makes the SDK pin RightContentColumn.MinWidth to a stable
                 value (no star-column collapse), so the tabs always stop where the buttons
                 begin.

                 Left gap between the tab strip's right edge (or the scroll-forward button in
                 overflow mode) and the pin button's left edge. -->
            <Thickness x:Key="TitleBarFooterLeftGap">12,0,0,0</Thickness>
            <!-- Total width occupied by the overlay button cluster, and therefore the width
                 the footer spacer must reserve so the reserved strip region and the overlay
                 line up exactly. = Pin 40 + Close 40 (both TitleBarButtonWidth) + left gap 12
                 (TitleBarFooterLeftGap) + right inset 0 = 92. With this the tab right edge lands
                 at window-92 and the pin left edge at window-80, giving the consistent 12px gap,
                 and the close button sits flush against the window's right edge.

                 IMPORTANT: the space is reserved EXACTLY ONCE, by the TabStripFooter spacer
                 (its Auto column pins RightContentColumn.MinWidth). The TabView's right Padding
                 must stay 0 (TabViewTabStripRightPadding) — Padding is applied to the whole
                 strip container and the footer is a separate column INSIDE it, so a non-zero
                 right Padding would stack on top of the footer and double-reserve. -->
            <x:Double x:Key="TitleBarButtonsClusterWidth">92</x:Double>
            <!-- The footer spacer alone reserves the cluster width, so the strip needs no extra
                 right padding. Keep this zero to avoid double-reserving (see note above). -->
            <Thickness x:Key="TabViewTabStripRightPadding">0,0,0,0</Thickness>
            <SolidColorBrush x:Key="SystemAccentColorBrush" Color="{ThemeResource SystemAccentColor}" />

            <Duration x:Key="HoverIndicatorAnimationDuration">0:0:0.2</Duration>
            <Duration x:Key="ActiveIndicatorAnimationDuration">0:0:0.3</Duration>

            <Style TargetType="TabViewItem">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="6" />
                <!-- No outer right margin: the SDK's equal-mode overflow test counts only
                     tabWidth*count, NOT the item margin, so an outer margin makes the laid-out
                     strip wider than the SDK thinks and spuriously trips the scroll buttons even
                     when the tabs fill exactly. The inter-tab gap is instead applied INSIDE the
                     tab, on the TabBackground pill (see its Margin below), so it is part of the
                     measured tab width. -->
                <Setter Property="Margin" Value="0,1,0,0" />
                <Setter Property="Padding" Value="3,0,3,0" />
                <Setter Property="MinHeight" Value="32" />
                <Setter Property="Height" Value="32" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabViewItem">
                            <Grid x:Name="LayoutRoot" Background="Transparent" Height="32">
                                <!-- Rounded floating tab background pill -->
                                <Border x:Name="TabBackground"
                                        Height="26"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="{TemplateBinding CornerRadius}"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Top"
                                        Margin="0,3,6,0">
                                    <Grid>
                                        <!-- Header content (Emoji, title, edit button) -->
                                        <ContentPresenter x:Name="ContentPresenter"
                                                          Content="{TemplateBinding Header}"
                                                          ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                          Margin="{TemplateBinding Padding}"
                                                          FontWeight="Normal">
                                            <ContentPresenter.Foreground>
                                                <SolidColorBrush x:Name="TextForegroundBrush" Color="{ThemeResource TabViewItemHeaderForegroundColor}" />
                                            </ContentPresenter.Foreground>
                                        </ContentPresenter>
                                    </Grid>
                                </Border>

                                <!-- Indication bar under active tab, perfectly aligned at bottom of row.
                                     The grid is inset by the same right margin (6) as the TabBackground
                                     pill so its bounds match the visible tab exactly; this keeps the
                                     5%/90%/5% column split tracking the pill rather than the full row. -->
                                <Grid VerticalAlignment="Bottom" Height="2" Margin="0,0,6,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="5*" />
                                        <ColumnDefinition Width="90*" />
                                        <ColumnDefinition Width="5*" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="ActiveIndicator"
                                            Grid.Column="1"
                                            Height="2"
                                            CornerRadius="1"
                                            Opacity="0"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Border.Background>
                                            <SolidColorBrush x:Name="ActiveIndicatorBrush" Color="{ThemeResource SystemAccentColor}" />
                                        </Border.Background>
                                        <Border.RenderTransform>
                                            <ScaleTransform x:Name="ActiveIndicatorScale" ScaleX="0" />
                                        </Border.RenderTransform>
                                    </Border>
                                </Grid>

                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="ActiveIndicator"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0"
                                                                 Duration="{StaticResource HoverIndicatorAnimationDuration}">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="ActiveIndicatorScale"
                                                                 Storyboard.TargetProperty="ScaleX"
                                                                 To="0"
                                                                 Duration="{StaticResource HoverIndicatorAnimationDuration}">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ColorAnimation Storyboard.TargetName="ActiveIndicatorBrush"
                                                                Storyboard.TargetProperty="Color"
                                                                To="{ThemeResource TabViewItemHeaderHoverIndicatorColor}"
                                                                Duration="{StaticResource HoverIndicatorAnimationDuration}">
                                                    <ColorAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </ColorAnimation.EasingFunction>
                                                </ColorAnimation>
                                                <ColorAnimation Storyboard.TargetName="TextForegroundBrush"
                                                                Storyboard.TargetProperty="Color"
                                                                To="{ThemeResource TabViewItemHeaderForegroundColor}"
                                                                Duration="{StaticResource HoverIndicatorAnimationDuration}">
                                                    <ColorAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </ColorAnimation.EasingFunction>
                                                </ColorAnimation>
                                            </Storyboard>
                                            <VisualState.Setters>
                                                <Setter Target="TabBackground.Background" Value="Transparent" />
                                                <Setter Target="ContentPresenter.FontWeight" Value="Normal" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="ActiveIndicator"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1"
                                                                 Duration="{StaticResource HoverIndicatorAnimationDuration}">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="ActiveIndicatorScale"
                                                                 Storyboard.TargetProperty="ScaleX"
                                                                 To="0.6"
                                                                 Duration="{StaticResource HoverIndicatorAnimationDuration}">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ColorAnimation Storyboard.TargetName="ActiveIndicatorBrush"
                                                                Storyboard.TargetProperty="Color"
                                                                To="{ThemeResource TabViewItemHeaderHoverIndicatorColor}"
                                                                Duration="{StaticResource HoverIndicatorAnimationDuration}">
                                                    <ColorAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </ColorAnimation.EasingFunction>
                                                </ColorAnimation>
                                                <ColorAnimation Storyboard.TargetName="TextForegroundBrush"
                                                                Storyboard.TargetProperty="Color"
                                                                To="{ThemeResource TabViewItemHeaderForegroundColor}"
                                                                Duration="{StaticResource HoverIndicatorAnimationDuration}">
                                                    <ColorAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </ColorAnimation.EasingFunction>
                                                </ColorAnimation>
                                            </Storyboard>
                                            <VisualState.Setters>
                                                <Setter Target="TabBackground.Background" Value="Transparent" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="ActiveIndicator"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1"
                                                                 Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="ActiveIndicatorScale"
                                                                 Storyboard.TargetProperty="ScaleX"
                                                                 To="1"
                                                                 Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ColorAnimation Storyboard.TargetName="ActiveIndicatorBrush"
                                                                Storyboard.TargetProperty="Color"
                                                                To="{ThemeResource SystemAccentColor}"
                                                                Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                                    <ColorAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </ColorAnimation.EasingFunction>
                                                </ColorAnimation>
                                                <ColorAnimation Storyboard.TargetName="TextForegroundBrush"
                                                                Storyboard.TargetProperty="Color"
                                                                To="{ThemeResource TabViewItemHeaderForegroundSelectedColor}"
                                                                Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                                    <ColorAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </ColorAnimation.EasingFunction>
                                                </ColorAnimation>
                                            </Storyboard>
                                            <VisualState.Setters>
                                                <Setter Target="TabBackground.Background" Value="Transparent" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Selected">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="ActiveIndicator"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1"
                                                                 Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="ActiveIndicatorScale"
                                                                 Storyboard.TargetProperty="ScaleX"
                                                                 To="1"
                                                                 Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ColorAnimation Storyboard.TargetName="ActiveIndicatorBrush"
                                                                Storyboard.TargetProperty="Color"
                                                                To="{ThemeResource SystemAccentColor}"
                                                                Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                                    <ColorAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </ColorAnimation.EasingFunction>
                                                </ColorAnimation>
                                                <ColorAnimation Storyboard.TargetName="TextForegroundBrush"
                                                                Storyboard.TargetProperty="Color"
                                                                To="{ThemeResource TabViewItemHeaderForegroundSelectedColor}"
                                                                Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                                    <ColorAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </ColorAnimation.EasingFunction>
                                                </ColorAnimation>
                                            </Storyboard>
                                            <VisualState.Setters>
                                                <Setter Target="TabBackground.Background" Value="Transparent" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="PointerOverSelected">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="ActiveIndicator"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1"
                                                                 Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="ActiveIndicatorScale"
                                                                 Storyboard.TargetProperty="ScaleX"
                                                                 To="1"
                                                                 Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ColorAnimation Storyboard.TargetName="ActiveIndicatorBrush"
                                                                Storyboard.TargetProperty="Color"
                                                                To="{ThemeResource SystemAccentColor}"
                                                                Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                                    <ColorAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </ColorAnimation.EasingFunction>
                                                </ColorAnimation>
                                                <ColorAnimation Storyboard.TargetName="TextForegroundBrush"
                                                                Storyboard.TargetProperty="Color"
                                                                To="{ThemeResource TabViewItemHeaderForegroundSelectedColor}"
                                                                Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                                    <ColorAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </ColorAnimation.EasingFunction>
                                                </ColorAnimation>
                                            </Storyboard>
                                            <VisualState.Setters>
                                                <Setter Target="TabBackground.Background" Value="Transparent" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="PressedSelected">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="ActiveIndicator"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1"
                                                                 Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="ActiveIndicatorScale"
                                                                 Storyboard.TargetProperty="ScaleX"
                                                                 To="1"
                                                                 Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ColorAnimation Storyboard.TargetName="ActiveIndicatorBrush"
                                                                Storyboard.TargetProperty="Color"
                                                                To="{ThemeResource SystemAccentColor}"
                                                                Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                                    <ColorAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </ColorAnimation.EasingFunction>
                                                </ColorAnimation>
                                                <ColorAnimation Storyboard.TargetName="TextForegroundBrush"
                                                                Storyboard.TargetProperty="Color"
                                                                To="{ThemeResource TabViewItemHeaderForegroundSelectedColor}"
                                                                Duration="{StaticResource ActiveIndicatorAnimationDuration}">
                                                    <ColorAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </ColorAnimation.EasingFunction>
                                                </ColorAnimation>
                                            </Storyboard>
                                            <VisualState.Setters>
                                                <Setter Target="TabBackground.Background" Value="Transparent" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                    <VisualStateGroup x:Name="DisabledStates">
                                        <VisualState x:Name="Enabled" />
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="LayoutRoot.Opacity" Value="0.5" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="TitleBarButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Width" Value="{StaticResource TitleBarButtonWidth}" />
                <Setter Property="MinHeight" Value="32" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Stretch" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="RootGrid" Background="Transparent" CornerRadius="0">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="RootGrid.Background" Value="{ThemeResource TitleBarButtonBackgroundPointerOver}" />
                                                <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TitleBarButtonForegroundPointerOver}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="RootGrid.Background" Value="{ThemeResource TitleBarButtonBackgroundPressed}" />
                                                <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TitleBarButtonForegroundPressed}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="RootGrid.Opacity" Value="0.5" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter x:Name="ContentPresenter"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="CloseTitleBarButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="RootGrid" Background="Transparent" CornerRadius="0">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="RootGrid.Background" Value="{ThemeResource CloseButtonBackgroundPointerOver}" />
                                                <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource CloseButtonForegroundPointerOver}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="RootGrid.Background" Value="{ThemeResource CloseButtonBackgroundPressed}" />
                                                <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource CloseButtonForegroundPressed}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="RootGrid.Opacity" Value="0.5" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter x:Name="ContentPresenter"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

              <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="Transparent" />
                    <SolidColorBrush x:Key="TitleBarButtonBackgroundPointerOver" Color="#363636" />
                    <SolidColorBrush x:Key="TitleBarButtonBackgroundPressed" Color="#30FFFFFF" />
                    <SolidColorBrush x:Key="TitleBarButtonForegroundPointerOver" Color="White" />
                    <SolidColorBrush x:Key="TitleBarButtonForegroundPressed" Color="White" />
                    <SolidColorBrush x:Key="CloseButtonBackgroundPointerOver" Color="#C42B1C" />
                    <SolidColorBrush x:Key="CloseButtonBackgroundPressed" Color="#B0271A" />
                    <SolidColorBrush x:Key="CloseButtonForegroundPointerOver" Color="White" />
                    <SolidColorBrush x:Key="CloseButtonForegroundPressed" Color="White" />
                    <SolidColorBrush x:Key="TabViewItemHeaderBackgroundInactive" Color="#0FFFFFFF" />
                    <SolidColorBrush x:Key="TabViewItemHeaderBackgroundInactivePointerOver" Color="#22FFFFFF" />
                    <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelected" Color="#22FFFFFF" />
                    <SolidColorBrush x:Key="TabViewItemHeaderBackgroundPressed" Color="#22FFFFFF" />
                    <Color x:Key="TabViewItemHeaderForegroundColor">#99FFFFFF</Color>
                    <Color x:Key="TabViewItemHeaderForegroundPointerOverColor">#E6FFFFFF</Color>
                    <Color x:Key="TabViewItemHeaderForegroundPressedColor">#E6FFFFFF</Color>
                    <Color x:Key="TabViewItemHeaderForegroundSelectedColor">White</Color>
                    <SolidColorBrush x:Key="TabViewItemHeaderForeground" Color="{ThemeResource TabViewItemHeaderForegroundColor}" />
                    <SolidColorBrush x:Key="TabViewItemHeaderForegroundPointerOver" Color="{ThemeResource TabViewItemHeaderForegroundPointerOverColor}" />
                    <SolidColorBrush x:Key="TabViewItemHeaderForegroundPressed" Color="{ThemeResource TabViewItemHeaderForegroundPressedColor}" />
                    <SolidColorBrush x:Key="TabViewItemHeaderForegroundSelected" Color="{ThemeResource TabViewItemHeaderForegroundSelectedColor}" />
                    <Color x:Key="TabViewItemHeaderHoverIndicatorColor">#55FFFFFF</Color>
                    <SolidColorBrush x:Key="TabViewItemHeaderHoverIndicatorBrush" Color="{ThemeResource TabViewItemHeaderHoverIndicatorColor}" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="Transparent" />
                    <SolidColorBrush x:Key="TitleBarButtonBackgroundPointerOver" Color="#10000000" />
                    <SolidColorBrush x:Key="TitleBarButtonBackgroundPressed" Color="#20000000" />
                    <SolidColorBrush x:Key="TitleBarButtonForegroundPointerOver" Color="Black" />
                    <SolidColorBrush x:Key="TitleBarButtonForegroundPressed" Color="Black" />
                    <SolidColorBrush x:Key="CloseButtonBackgroundPointerOver" Color="#C42B1C" />
                    <SolidColorBrush x:Key="CloseButtonBackgroundPressed" Color="#B0271A" />
                    <SolidColorBrush x:Key="CloseButtonForegroundPointerOver" Color="White" />
                    <SolidColorBrush x:Key="CloseButtonForegroundPressed" Color="White" />
                    <SolidColorBrush x:Key="TabViewItemHeaderBackgroundInactive" Color="#0F000000" />
                    <SolidColorBrush x:Key="TabViewItemHeaderBackgroundInactivePointerOver" Color="#22000000" />
                    <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelected" Color="#22000000" />
                    <SolidColorBrush x:Key="TabViewItemHeaderBackgroundPressed" Color="#22000000" />
                    <Color x:Key="TabViewItemHeaderForegroundColor">#66000000</Color>
                    <Color x:Key="TabViewItemHeaderForegroundPointerOverColor">#E6000000</Color>
                    <Color x:Key="TabViewItemHeaderForegroundPressedColor">#E6000000</Color>
                    <Color x:Key="TabViewItemHeaderForegroundSelectedColor">Black</Color>
                    <SolidColorBrush x:Key="TabViewItemHeaderForeground" Color="{ThemeResource TabViewItemHeaderForegroundColor}" />
                    <SolidColorBrush x:Key="TabViewItemHeaderForegroundPointerOver" Color="{ThemeResource TabViewItemHeaderForegroundPointerOverColor}" />
                    <SolidColorBrush x:Key="TabViewItemHeaderForegroundPressed" Color="{ThemeResource TabViewItemHeaderForegroundPressedColor}" />
                    <SolidColorBrush x:Key="TabViewItemHeaderForegroundSelected" Color="{ThemeResource TabViewItemHeaderForegroundSelectedColor}" />
                    <Color x:Key="TabViewItemHeaderHoverIndicatorColor">#55000000</Color>
                    <SolidColorBrush x:Key="TabViewItemHeaderHoverIndicatorBrush" Color="{ThemeResource TabViewItemHeaderHoverIndicatorColor}" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="Transparent" />
                    <SolidColorBrush x:Key="TitleBarButtonBackgroundPointerOver" Color="#363636" />
                    <SolidColorBrush x:Key="TitleBarButtonBackgroundPressed" Color="#30FFFFFF" />
                    <SolidColorBrush x:Key="TitleBarButtonForegroundPointerOver" Color="White" />
                    <SolidColorBrush x:Key="TitleBarButtonForegroundPressed" Color="White" />
                    <SolidColorBrush x:Key="CloseButtonBackgroundPointerOver" Color="#C42B1C" />
                    <SolidColorBrush x:Key="CloseButtonBackgroundPressed" Color="#B0271A" />
                    <SolidColorBrush x:Key="CloseButtonForegroundPointerOver" Color="White" />
                    <SolidColorBrush x:Key="CloseButtonForegroundPressed" Color="White" />
                    <SolidColorBrush x:Key="TabViewItemHeaderBackgroundInactive" Color="#0FFFFFFF" />
                    <SolidColorBrush x:Key="TabViewItemHeaderBackgroundInactivePointerOver" Color="#22FFFFFF" />
                    <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelected" Color="#22FFFFFF" />
                    <SolidColorBrush x:Key="TabViewItemHeaderBackgroundPressed" Color="#22FFFFFF" />
                    <Color x:Key="TabViewItemHeaderForegroundColor">#99FFFFFF</Color>
                    <Color x:Key="TabViewItemHeaderForegroundPointerOverColor">#E6FFFFFF</Color>
                    <Color x:Key="TabViewItemHeaderForegroundPressedColor">#E6FFFFFF</Color>
                    <Color x:Key="TabViewItemHeaderForegroundSelectedColor">White</Color>
                    <SolidColorBrush x:Key="TabViewItemHeaderForeground" Color="{ThemeResource TabViewItemHeaderForegroundColor}" />
                    <SolidColorBrush x:Key="TabViewItemHeaderForegroundPointerOver" Color="{ThemeResource TabViewItemHeaderForegroundPointerOverColor}" />
                    <SolidColorBrush x:Key="TabViewItemHeaderForegroundPressed" Color="{ThemeResource TabViewItemHeaderForegroundPressedColor}" />
                    <SolidColorBrush x:Key="TabViewItemHeaderForegroundSelected" Color="{ThemeResource TabViewItemHeaderForegroundSelectedColor}" />
                    <Color x:Key="TabViewItemHeaderHoverIndicatorColor">#55FFFFFF</Color>
                    <SolidColorBrush x:Key="TabViewItemHeaderHoverIndicatorBrush" Color="{ThemeResource TabViewItemHeaderHoverIndicatorColor}" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="Transparent" />
                    <SolidColorBrush x:Key="TitleBarButtonBackgroundPointerOver" Color="{ThemeResource SystemColorHighlightColor}" />
                    <SolidColorBrush x:Key="TitleBarButtonBackgroundPressed" Color="{ThemeResource SystemColorHighlightColor}" />
                    <SolidColorBrush x:Key="TitleBarButtonForegroundPointerOver" Color="{ThemeResource SystemColorHighlightTextColor}" />
                    <SolidColorBrush x:Key="TitleBarButtonForegroundPressed" Color="{ThemeResource SystemColorHighlightTextColor}" />
                    <SolidColorBrush x:Key="CloseButtonBackgroundPointerOver" Color="{ThemeResource SystemColorHighlightColor}" />
                    <SolidColorBrush x:Key="CloseButtonBackgroundPressed" Color="{ThemeResource SystemColorHighlightColor}" />
                    <SolidColorBrush x:Key="CloseButtonForegroundPointerOver" Color="{ThemeResource SystemColorHighlightTextColor}" />
                    <SolidColorBrush x:Key="CloseButtonForegroundPressed" Color="{ThemeResource SystemColorHighlightTextColor}" />
                    <SolidColorBrush x:Key="TabViewItemHeaderBackgroundInactive" Color="Transparent" />
                    <SolidColorBrush x:Key="TabViewItemHeaderBackgroundInactivePointerOver" Color="{ThemeResource SystemColorHighlightColor}" />
                    <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelected" Color="{ThemeResource SystemColorHighlightColor}" />
                    <SolidColorBrush x:Key="TabViewItemHeaderBackgroundPressed" Color="{ThemeResource SystemColorHighlightColor}" />
                    <Color x:Key="TabViewItemHeaderForegroundColor">{ThemeResource SystemColorWindowTextColor}</Color>
                    <Color x:Key="TabViewItemHeaderForegroundPointerOverColor">{ThemeResource SystemColorHighlightTextColor}</Color>
                    <Color x:Key="TabViewItemHeaderForegroundPressedColor">{ThemeResource SystemColorHighlightTextColor}</Color>
                    <Color x:Key="TabViewItemHeaderForegroundSelectedColor">{ThemeResource SystemColorHighlightTextColor}</Color>
                    <SolidColorBrush x:Key="TabViewItemHeaderForeground" Color="{ThemeResource TabViewItemHeaderForegroundColor}" />
                    <SolidColorBrush x:Key="TabViewItemHeaderForegroundPointerOver" Color="{ThemeResource TabViewItemHeaderForegroundPointerOverColor}" />
                    <SolidColorBrush x:Key="TabViewItemHeaderForegroundPressed" Color="{ThemeResource TabViewItemHeaderForegroundPressedColor}" />
                    <SolidColorBrush x:Key="TabViewItemHeaderForegroundSelected" Color="{ThemeResource TabViewItemHeaderForegroundSelectedColor}" />
                    <Color x:Key="TabViewItemHeaderHoverIndicatorColor">{ThemeResource SystemColorWindowTextColor}</Color>
                    <SolidColorBrush x:Key="TabViewItemHeaderHoverIndicatorBrush" Color="{ThemeResource TabViewItemHeaderHoverIndicatorColor}" />
                </ResourceDictionary>
              </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Background="Transparent">
        <TabView
            x:Name="BufferTabView"
            IsAddTabButtonVisible="False"
            CanReorderTabs="False"
            TabWidthMode="Equal"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch"
            Padding="{StaticResource TabViewTabStripRightPadding}"
            BorderBrush="Transparent"
            BorderThickness="0">

            <TabView.Resources>
                <Thickness x:Key="TabViewBorderThickness">0</Thickness>
                <SolidColorBrush x:Key="TabViewBorderBrush" Color="Transparent" />
                <SolidColorBrush x:Key="TabViewItemSeparatorBrush" Color="Transparent" />

                <!-- Equal-mode tab sizing.

                     IMPORTANT: in Equal mode the SDK does NOT shrink tabs to a star column.
                     The tab items live inside a horizontally scrollable ScrollViewer, so each
                     item is measured against its MaxWidth, not against (window - footer). A
                     large static MaxWidth therefore does NOT make the tabs "stretch then
                     shrink" — instead every tab measures near MaxWidth and the strip overflows
                     and clips off the right edge (and the scroll-button visibility test, driven
                     by the same comparison, never fires). That is exactly the overflow bug a
                     static MaxWidth=1000 produced.

                     The per-tab MaxWidth that actually fills the row without overflowing depends
                     on the live window width, and TabViewItem resource keys are read once and
                     cannot be runtime-injected. So the real cap is applied in code-behind
                     (UpdateEqualTabMaxWidth) by setting TabViewItem.MaxWidth = available/count on
                     every size change. These resources are only static bounds: MaxWidth here is a
                     non-binding ceiling, and MinWidth is the 100px floor below which tabs stop
                     shrinking, overflow, and the SDK surfaces the scroll buttons. -->
                <x:Double x:Key="TabViewItemMinWidth">100</x:Double>
                <x:Double x:Key="TabViewItemMaxWidth">1000</x:Double>

                <!-- Compact scroll buttons styling -->
                <x:Double x:Key="TabViewItemScrollButtonWidth">20</x:Double>
                <x:Double x:Key="TabViewItemScrollButonFontSize">8</x:Double>
                <Thickness x:Key="TabViewItemLeftScrollButtonContainerPadding">0,0,2,3</Thickness>
                <Thickness x:Key="TabViewItemRightScrollButtonContainerPadding">2,0,0,3</Thickness>

                <!-- Modern WinUI tooltip shared by the pin and close buttons -->
                <Style TargetType="ToolTip">
                    <Setter Property="Background" Value="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" />
                    <Setter Property="BorderBrush" Value="{ThemeResource SystemControlTransientBorderBrush}" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="CornerRadius" Value="4" />
                    <Setter Property="Padding" Value="8,5,8,5" />
                    <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                    <Setter Property="FontSize" Value="12" />
                    <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
                </Style>
            </TabView.Resources>

            <TabView.TabStripHeader>
                <Border
                    x:Name="TitleBarIconDragArea"
                    Padding="10,0,6,0"
                    MinHeight="{StaticResource TitleBarRowHeight}"
                    VerticalAlignment="Stretch"
                    Background="Transparent">
                    <Image
                        Source="ms-appx:///Assets/Square44x44Logo.scale-200.png"
                        Width="16"
                        Height="16"
                        VerticalAlignment="Center"
                        ToolTipService.ToolTip="Jott" />
                </Border>
            </TabView.TabStripHeader>

            <!-- Fixed-width transparent spacer reserving exactly the overlay button cluster's
                 width (TitleBarButtonsClusterWidth = 92) in the tab strip, and the ONLY place
                 that width is reserved (the TabView's right Padding is 0 to avoid stacking — see
                 the TabViewTabStripRightPadding note above). A fixed footer width makes the SDK
                 pin RightContentColumn.MinWidth to a stable 92 (no star-column collapse, the
                 defect of the earlier footer-hosted approach), so the tabs stop where the
                 buttons begin and never slide under them. The spacer is IsHitTestVisible=False
                 so it never blocks the overlay buttons drawn over it; the drag region (set in
                 MainWindow via SetTitleBar(TitleBarIconDragArea)) covers only the LEFT icon
                 area. -->
            <TabView.TabStripFooter>
                <Border
                    x:Name="TitleBarFooterSpacer"
                    Width="{StaticResource TitleBarButtonsClusterWidth}"
                    Height="{StaticResource TitleBarRowHeight}"
                    Background="Transparent"
                    IsHitTestVisible="False" />
            </TabView.TabStripFooter>
        </TabView>

        <!-- Pin and close buttons as a top-level OVERLAY anchored to the window's top-right
             corner. Being top-level (not inside any TabView column) they can never be clipped,
             unlike the two earlier footer-hosted attempts. The cluster occupies exactly
             TitleBarButtonsClusterWidth and lines up over the footer spacer: the pin's left
             gap (TitleBarFooterLeftGap) sits 12px past the tabs' right edge, and the close
             button sits flush against the window's right edge (no right inset). -->
        <StackPanel
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Height="{StaticResource TitleBarRowHeight}">
            <Button
                x:Name="PinButton"
                Style="{StaticResource TitleBarButtonStyle}"
                Margin="{StaticResource TitleBarFooterLeftGap}"
                ToolTipService.ToolTip="Pin window"
                Click="OnPinButtonClicked">
                <FontIcon
                    x:Name="PinIcon"
                    Glyph="&#xE718;"
                    FontSize="12" />
            </Button>
            <Button
                x:Name="CloseButton"
                Style="{StaticResource CloseTitleBarButtonStyle}"
                Margin="0"
                ToolTipService.ToolTip="Close"
                Click="OnCloseButtonClicked">
                <FontIcon
                    Glyph="&#xE8BB;"
                    FontSize="9" />
            </Button>
        </StackPanel>
    </Grid>
</UserControl>

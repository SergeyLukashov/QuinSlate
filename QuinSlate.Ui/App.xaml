<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="QuinSlate.Ui.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:QuinSlate.Ui">
    <Application.Resources>
        <ResourceDictionary>
            <!-- ============================================================================
                 SINGLE SOURCE OF TRUTH for the window/editor background gradient colours,
                 warmed toward the logo palette (amber #F2900F and warm grey #98948D).

                 The background is a four-corner BILINEAR MESH, not a straight ramp. Each
                 corner of the surface has its own colour and every pixel is a smooth blend of
                 the four (see DitheredGradientBrushFactory). The Start/End colours are the
                 diagonal endpoints (top-left / bottom-right); CornerTR/CornerBL are the other
                 two corners. The top-right corner carries a faint "whisper of amber" warmth;
                 the rest stay near-neutral so the field reads as dim, organic depth.

                 Change the gradient HERE and nowhere else. Everything derives from these
                 colours: the XAML fallback brushes below reference Start/End, and the C#
                 DitheredGradientBrushFactory (the brush actually shown) plus MainWindow's
                 flash-prevention fill READ them by key at runtime.
                 ============================================================================ -->
            <Color x:Key="AppGradientStartDark">#FF2B2B2B</Color>
            <Color x:Key="AppGradientEndDark">#FF242424</Color>
            <Color x:Key="AppGradientCornerTRDark">#FF302B23</Color>
            <Color x:Key="AppGradientCornerBLDark">#FF262626</Color>
            <Color x:Key="AppGradientStartLight">#FFFDFDFB</Color>
            <Color x:Key="AppGradientEndLight">#FFF5F5F3</Color>
            <Color x:Key="AppGradientCornerTRLight">#FFFCF7EF</Color>
            <Color x:Key="AppGradientCornerBLLight">#FFF8F8F6</Color>

            <!-- Compact, opaque presenter for the tray context menu. The Background is a
                 {ThemeResource} so it resolves against the menu presenter's own element theme
                 (which follows the tray helper window's RequestedTheme) rather than the app/Windows
                 theme — a manual light/dark override must theme the menu, not just its text. -->
            <Style x:Key="TrayMenuFlyoutPresenterStyle" TargetType="MenuFlyoutPresenter">
                <Setter Property="Background" Value="{ThemeResource SolidBackgroundFillColorBaseBrush}" />
                <Setter Property="Padding" Value="0,2,0,2" />
                <Setter Property="MinWidth" Value="150" />
            </Style>

            <ResourceDictionary.ThemeDictionaries>
                <!-- Fallback gradient brushes (shown only before the dithered brush is applied
                     on load, or if it cannot be built). They reference the colours above so the
                     palette stays single-sourced. The Default dictionary serves the dark theme. -->
                <ResourceDictionary x:Key="Default">
                    <LinearGradientBrush x:Key="AppBackgroundGradient" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{ThemeResource AppGradientStartDark}" Offset="0" />
                        <GradientStop Color="{ThemeResource AppGradientEndDark}" Offset="1" />
                    </LinearGradientBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <LinearGradientBrush x:Key="AppBackgroundGradient" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{ThemeResource AppGradientStartLight}" Offset="0" />
                        <GradientStop Color="{ThemeResource AppGradientEndLight}" Offset="1" />
                    </LinearGradientBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <LinearGradientBrush x:Key="AppBackgroundGradient" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{ThemeResource AppGradientStartDark}" Offset="0" />
                        <GradientStop Color="{ThemeResource AppGradientEndDark}" Offset="1" />
                    </LinearGradientBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <SolidColorBrush x:Key="AppBackgroundGradient" Color="{ThemeResource SystemColorWindowColor}" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="ms-appx:///Themes/TextBoxStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>

<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="QuinSlate.Ui.Components.AboutView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Themes/AboutResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- The card fills its hosting window (AboutWindow sizes the window to a fixed card size).
         Header, body and footer are the three rows: the body row absorbs any slack so the
         footer always sits flush at the bottom. No corner radius or border here — the hosting
         window owns the single rounded outline (see AboutWindow's DWM corner preference). -->
    <Grid x:Name="RootGrid" Background="{ThemeResource AppBackgroundGradient}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header: title bar (draggable region; see AboutWindow's caption handling) + separator -->
        <StackPanel Grid.Row="0" Spacing="0">
            <Grid x:Name="HeaderBar" Height="{StaticResource AboutBarHeight}" Padding="20,0,12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Image Source="ms-appx:///Assets/Square44x44Logo.scale-200.png" Width="18" Height="18" VerticalAlignment="Center" />
                    <TextBlock x:Name="TitleBarText"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Button Grid.Column="1"
                        Style="{StaticResource CloseButtonStyle}"
                        Click="OnCloseClicked"
                        VerticalAlignment="Center"
                        ToolTipService.ToolTip="Close">
                    <FontIcon Glyph="&#xE8BB;" FontSize="9" />
                </Button>
            </Grid>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
        </StackPanel>

        <!-- Body -->
        <Border Grid.Row="1" Padding="20">
            <StackPanel Spacing="16">
                <!-- Logo  -->
                <StackPanel Spacing="18">
                    <Image x:Name="LogoImage" Height="40" Stretch="Uniform" HorizontalAlignment="Left" />
                    <StackPanel Spacing="10">
                        <TextBlock Text="Five slates. Open, type, done. Five by design. The limit is the point."
                                   TextWrapping="Wrap"
                                   FontSize="13"
                                   LineHeight="18"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="Everything saves as plain text on your machine. Your words never leave it."
                                   TextWrapping="Wrap"
                                   FontSize="13"
                                   LineHeight="18"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>

                <!-- Data path card -->
                <Border CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        Padding="16">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xED25;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="Your data lives here" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Path is middle-ellipsized in code (WinUI has no middle TextTrimming);
                             the full path is carried in the tooltip and on the Copy-path button. -->
                        <TextBlock x:Name="PathText"
                                   FontFamily="Consolas"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextWrapping="NoWrap"
                                   TextTrimming="None"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Style="{StaticResource ActionButtonStyle}" Click="OnOpenFolderClicked">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8B7;" FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Text="Open folder" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ActionButtonStyle}" Click="OnCopyPathClicked">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8C8;" FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Text="Copy path" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Hotkey and quick-math sit as a tight pair, closer to each other than to the
                     card above (the outer StackPanel's 16px spacing). -->
                <StackPanel Spacing="6">
                    <!-- Global hotkey -->
                    <Grid Height="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Global hotkey" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <Border Style="{StaticResource PillBorderStyle}"><TextBlock Style="{StaticResource PillTextStyle}" Text="Ctrl" /></Border>
                            <Border Style="{StaticResource PillBorderStyle}"><TextBlock Style="{StaticResource PillTextStyle}" Text="Shift" /></Border>
                            <Border Style="{StaticResource PillBorderStyle}"><TextBlock Style="{StaticResource PillTextStyle}" Text="Q" /></Border>
                        </StackPanel>
                    </Grid>

                    <!-- Quick math -->
                    <Grid Height="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Quick math" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBlock Text="56 * 3" FontSize="12" FontFamily="Cascadia Code" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                            <Border Style="{StaticResource PillBorderStyle}"><TextBlock Style="{StaticResource PillTextStyle}" Text="=" /></Border>
                            <TextBlock Text="168" FontSize="12" FontFamily="Cascadia Code" Foreground="{StaticResource AccentColorBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Footer: separator + links + version -->
        <StackPanel Grid.Row="2" Spacing="0">
            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <Grid Height="{StaticResource AboutBarHeight}" Padding="12,0,18,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <Button Style="{StaticResource FlatLinkButtonStyle}" Click="OnReportIssueClicked">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE8A1;" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="Report an issue" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource FlatLinkButtonStyle}" Click="OnMitLicenseClicked">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE8A5;" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="MIT license" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <TextBlock x:Name="VersionText"
                           Grid.Column="1"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           VerticalAlignment="Center" />
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>

<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="QuinSlate.Ui.Components.AboutView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Single source of truth for the header/footer bar height so they always match. -->
        <x:Double x:Key="AboutBarHeight">44</x:Double>

        <!-- Self-contained button styles -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="ButtonGrid" Background="Transparent" CornerRadius="4">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="ButtonGrid.Background" Value="#C42B1C" />
                                            <Setter Target="ContentPresenter.Foreground" Value="White" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="ButtonGrid.Background" Value="#B0271A" />
                                            <Setter Target="ContentPresenter.Foreground" Value="White" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter x:Name="ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FlatLinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,4,8,4" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="ButtonGrid" Background="Transparent" CornerRadius="4">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="ButtonGrid.Background" Value="{ThemeResource ControlFillColorDefaultBrush}" />
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="ButtonGrid.Background" Value="{ThemeResource ControlFillColorSecondaryBrush}" />
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter x:Name="ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6,12,6" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="ButtonGrid" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="{TemplateBinding CornerRadius}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="ButtonGrid.Background" Value="{ThemeResource ControlFillColorSecondaryBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="ButtonGrid.Background" Value="{ThemeResource ControlFillColorTertiaryBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter x:Name="ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- The exact Windows accent colour as a brush (the raw SystemAccentColor is a Color,
             not a Brush). Matches the inline calculator result colour used in the editor. -->
        <SolidColorBrush x:Key="AccentColorBrush" Color="{ThemeResource SystemAccentColor}" />

        <!-- Key-cap "pill" identical to the tray peek view's hotkey pills (Border + text). -->
        <Style x:Key="PillBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,3,8,3" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="PillTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>
    </UserControl.Resources>

    <!-- No corner radius or border here: the hosting window owns the single rounded outline
         (see AboutWindow's DWM corner preference). A second rounded border drawn by this card
         would not align with the window's corners and would read as a detached edge. -->
    <Grid x:Name="RootGrid"
          Width="480"
          VerticalAlignment="Top"
          Background="{ThemeResource AppBackgroundGradient}">

        <StackPanel Spacing="0">
            <!-- Title Bar (draggable region; see AboutWindow's WM_NCHITTEST handling) -->
            <Grid x:Name="HeaderBar" Height="{StaticResource AboutBarHeight}" Padding="20,0,12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0" Spacing="8" VerticalAlignment="Center">
                    <Image Source="ms-appx:///Assets/Square44x44Logo.scale-200.png"
                           Width="18"
                           Height="18"
                           VerticalAlignment="Center" />
                    <TextBlock x:Name="TitleBarText"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Button Grid.Column="1"
                        Style="{StaticResource CloseButtonStyle}"
                        Click="OnCloseClicked"
                        VerticalAlignment="Center"
                        ToolTipService.ToolTip="Close">
                    <FontIcon Glyph="&#xE8BB;" FontSize="9" />
                </Button>
            </Grid>

            <!-- Full-width separator between the title bar and the content -->
            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- Content -->
            <Border Padding="20,20,20,20">
            <StackPanel Spacing="0">
            <!-- Logo & tagline -->
            <StackPanel Margin="0,0,0,16" Spacing="10">
                <Image x:Name="LogoImage"
                       Height="40"
                       Stretch="Uniform"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center" />
                <TextBlock Text="Five slates. Open, type, done."
                           FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Main Description -->
            <TextBlock Text="The fastest place to dump a thought — without ever opening, naming, or saving a thing."
                       TextWrapping="Wrap"
                       FontSize="13"
                       LineHeight="18"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,16" />

            <!-- Path Location Card -->
            <Border CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                    Padding="16"
                    Margin="0,0,0,16">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xED25;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="Your data lives here"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock x:Name="PathText"
                               FontFamily="Consolas"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Style="{StaticResource ActionButtonStyle}" Click="OnOpenFolderClicked">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8B7;" FontSize="12" VerticalAlignment="Center" />
                                <TextBlock Text="Open folder" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ActionButtonStyle}" Click="OnCopyPathClicked">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8C8;" FontSize="12" VerticalAlignment="Center" />
                                <TextBlock Text="Copy path" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Global Hotkey Row -->
            <Grid Height="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Global hotkey"
                           Grid.Column="0"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Border Style="{StaticResource PillBorderStyle}">
                        <TextBlock Style="{StaticResource PillTextStyle}" Text="Ctrl" />
                    </Border>
                    <Border Style="{StaticResource PillBorderStyle}">
                        <TextBlock Style="{StaticResource PillTextStyle}" Text="Shift" />
                    </Border>
                    <Border Style="{StaticResource PillBorderStyle}">
                        <TextBlock Style="{StaticResource PillTextStyle}" Text="Q" />
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Quick Math Row -->
            <Grid Height="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Quick math"
                           Grid.Column="0"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="56 * 3" FontSize="12" FontFamily="Cascadia Code" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                    <Border Style="{StaticResource PillBorderStyle}">
                        <TextBlock Style="{StaticResource PillTextStyle}" Text="=" />
                    </Border>
                    <TextBlock Text="168" FontSize="12" FontFamily="Cascadia Code" Foreground="{StaticResource AccentColorBrush}" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
            </StackPanel>
            </Border>

            <!-- Full-width separator above the footer -->
            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- Footer (height matches the title bar via the shared AboutBarHeight resource) -->
            <Grid Height="{StaticResource AboutBarHeight}" Margin="0, -2, 0, 0" Padding="12,0,18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <Button Style="{StaticResource FlatLinkButtonStyle}" VerticalAlignment="Center" Click="OnReportIssueClicked">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE8A1;" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="Report an issue" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource FlatLinkButtonStyle}" VerticalAlignment="Center" Click="OnMitLicenseClicked">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE8A5;" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="MIT license" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <TextBlock x:Name="VersionText"
                           Grid.Column="1"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           VerticalAlignment="Center" />
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>

<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="QuinSlate.Ui.Components.EmojiPickerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <x:Double x:Key="EmojiItemSize">36</x:Double>
        <x:Double x:Key="EmojiRowHeight">38</x:Double>
        <x:Double x:Key="EmojiSheetWidth">266</x:Double>
        <x:Double x:Key="EmojiLabelFontSize">11</x:Double>

        <Style x:Key="CategoryHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource EmojiLabelFontSize}" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>

        <Style x:Key="EmojiCellHighlightStyle" TargetType="Border">
            <Setter Property="Width" Value="{StaticResource EmojiItemSize}" />
            <Setter Property="Height" Value="{StaticResource EmojiItemSize}" />
            <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
    </UserControl.Resources>

    <StackPanel
        x:Name="PickerRoot"
        Width="{StaticResource EmojiSheetWidth}"
        Spacing="4">
        <StackPanel.ChildrenTransitions>
            <TransitionCollection />
        </StackPanel.ChildrenTransitions>

        <TextBox
            x:Name="SearchBox"
            PlaceholderText="Search emoji…"
            Height="32"
            Margin="0,0,0,4" />

        <StackPanel
            x:Name="RecentContainer"
            Spacing="4"
            Margin="0,0,0,4"
            Visibility="Collapsed">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection />
            </StackPanel.ChildrenTransitions>
            <TextBlock Text="Recent" Style="{StaticResource CategoryHeaderStyle}" />
            <Canvas
                x:Name="RecentCanvas"
                Width="{StaticResource EmojiSheetWidth}"
                Height="{StaticResource EmojiRowHeight}"
                Background="Transparent"
                AutomationProperties.Name="Recent emoji">
                <Border
                    x:Name="RecentHoverHighlight"
                    Style="{StaticResource EmojiCellHighlightStyle}"
                    Background="{ThemeResource ListViewItemBackgroundPointerOver}" />
                <Border
                    x:Name="RecentPressedHighlight"
                    Style="{StaticResource EmojiCellHighlightStyle}"
                    Background="{ThemeResource ListViewItemBackgroundPressed}" />
            </Canvas>
        </StackPanel>

        <TextBlock
            x:Name="MatchesHeader"
            Text="Matches"
            Style="{StaticResource CategoryHeaderStyle}"
            Visibility="Collapsed" />

        <ScrollViewer
            x:Name="SheetScroller"
            Height="240"
            VerticalScrollMode="Enabled"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollMode="Disabled"
            HorizontalScrollBarVisibility="Disabled">
            <!-- Top-aligned: the canvas carries an explicit per-mode Height, and a
                 non-stretchable child centers in the viewport's leftover space —
                 short search results would float mid-viewport without this. -->
            <Canvas
                x:Name="SheetCanvas"
                Width="{StaticResource EmojiSheetWidth}"
                VerticalAlignment="Top"
                Background="Transparent"
                AutomationProperties.Name="Emoji grid">
                <Border
                    x:Name="SheetHoverHighlight"
                    Style="{StaticResource EmojiCellHighlightStyle}"
                    Background="{ThemeResource ListViewItemBackgroundPointerOver}" />
                <Border
                    x:Name="SheetPressedHighlight"
                    Style="{StaticResource EmojiCellHighlightStyle}"
                    Background="{ThemeResource ListViewItemBackgroundPressed}" />
            </Canvas>
        </ScrollViewer>

    </StackPanel>
</UserControl>

<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="QuinSlate.Ui.Components.EmojiPickerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:QuinSlate.Ui.Components"
    xmlns:models="using:QuinSlate.Ui.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <x:Double x:Key="EmojiItemSize">36</x:Double>
        <x:Double x:Key="EmojiRowHeight">38</x:Double>
        <x:Double x:Key="EmojiFontSize">19.8</x:Double>
        <x:Double x:Key="EmojiLabelFontSize">11</x:Double>
        <x:Double x:Key="CategoryHeaderHeight">15</x:Double>

        <Style x:Key="EmojiItemContainerStyle" TargetType="GridViewItem">
            <Setter Property="Margin" Value="1" />
            <Setter Property="Width" Value="{StaticResource EmojiItemSize}" />
            <Setter Property="Height" Value="{StaticResource EmojiItemSize}" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewItem">
                        <Border
                            x:Name="ContentBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="ContentBorder.Background" Value="{ThemeResource ListViewItemBackgroundPointerOver}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="ContentBorder.Background" Value="{ThemeResource ListViewItemBackgroundPressed}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EmojiTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource EmojiFontSize}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextLineBounds" Value="Tight" />
        </Style>

        <DataTemplate x:Key="EmojiItemTemplate" x:DataType="models:EmojiEntry">
            <TextBlock
                Text="{x:Bind Emoji}"
                AutomationProperties.Name="{x:Bind Keywords}"
                Style="{StaticResource EmojiTextStyle}" />
        </DataTemplate>

        <Style x:Key="EmojiGridViewStyle" TargetType="GridView">
            <Setter Property="ItemContainerStyle" Value="{StaticResource EmojiItemContainerStyle}" />
            <Setter Property="ItemTemplate" Value="{StaticResource EmojiItemTemplate}" />
            <Setter Property="IsItemClickEnabled" Value="True" />
            <Setter Property="SelectionMode" Value="None" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollMode" Value="Disabled" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ItemContainerTransitions">
                <Setter.Value>
                    <TransitionCollection />
                </Setter.Value>
            </Setter>
            <Setter Property="Transitions">
                <Setter.Value>
                    <TransitionCollection />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CategoryHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource EmojiLabelFontSize}" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>

        <Style x:Key="EmojiGroupHeaderStyle" TargetType="GridViewHeaderItem">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Height" Value="{StaticResource CategoryHeaderHeight}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="Transitions">
                <Setter.Value>
                    <TransitionCollection />
                </Setter.Value>
            </Setter>
            <Setter Property="ContentTransitions">
                <Setter.Value>
                    <TransitionCollection />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewHeaderItem">
                        <ContentPresenter
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Margin="{TemplateBinding Padding}"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <CollectionViewSource
            x:Name="EmojiGroupsSource"
            IsSourceGrouped="True"
            ItemsPath="Entries" />
    </UserControl.Resources>

    <StackPanel
        x:Name="PickerRoot"
        Width="266"
        Spacing="4">
        <StackPanel.ChildrenTransitions>
            <TransitionCollection />
        </StackPanel.ChildrenTransitions>

        <TextBox
            x:Name="SearchBox"
            PlaceholderText="Search emoji…"
            Height="32"
            Margin="0,0,0,4" />

        <StackPanel
            x:Name="RecentContainer"
            Spacing="4"
            Margin="0,0,0,4"
            Visibility="Collapsed">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection />
            </StackPanel.ChildrenTransitions>
            <TextBlock Text="Recent" Style="{StaticResource CategoryHeaderStyle}" />
            <GridView
                x:Name="RecentView"
                Height="{StaticResource EmojiRowHeight}"
                Style="{StaticResource EmojiGridViewStyle}"
                ItemClick="OnEmojiItemClick"
                ScrollViewer.VerticalScrollMode="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Disabled" />
        </StackPanel>

        <GridView
            x:Name="CategoryView"
            Height="240"
            Style="{StaticResource EmojiGridViewStyle}"
            ItemClick="OnEmojiItemClick">
            <GridView.GroupStyle>
                <GroupStyle HeaderContainerStyle="{StaticResource EmojiGroupHeaderStyle}">
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate x:DataType="models:EmojiGroup">
                            <TextBlock Text="{x:Bind Name}" Style="{StaticResource CategoryHeaderStyle}" />
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </GridView.GroupStyle>
        </GridView>

        <StackPanel
            x:Name="SearchResultsContainer"
            Spacing="4"
            Visibility="Collapsed">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection />
            </StackPanel.ChildrenTransitions>
            <TextBlock Text="Matches" Style="{StaticResource CategoryHeaderStyle}" />
            <GridView
                x:Name="SearchResultsView"
                Height="240"
                Style="{StaticResource EmojiGridViewStyle}"
                ItemClick="OnEmojiItemClick" />
        </StackPanel>

    </StackPanel>
</UserControl>

<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="QuinSlate.Ui.Components.LimitNoticeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:QuinSlate.Ui.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    IsHitTestVisible="False">

    <!-- Never interactive: the user is mid-keystroke when this appears, so it must not be able to
         take focus or swallow a click meant for the editor underneath. IsHitTestVisible is set on
         the control itself, which stops hit-testing before it reaches anything inside.

         A hand-built pill rather than an InfoBar: an InfoBar carries its own Fluent chrome (icon
         column, title/message stack, ~48px minimum height) that cannot be brought down to this size
         or onto the app's own transient-surface palette without gutting its template. The brushes,
         corner radius, and font below are shared with the rest of the app — the transient-surface
         background of the panel's ToolTip style, and the same divider stroke the peek window draws
         its header/footer separators with — so the notice reads as part of the app and follows the
         theme in both light and dark.

         The drop shadow is a hand-rolled Composition DropShadow (see LimitNoticeView.xaml.cs), not a
         ThemeShadow: at this SDK target ThemeShadow projects onto XAML receiver surfaces, and the
         only thing behind the pill is the WebView2's separate airspace, so a ThemeShadow would draw
         nothing. The Composition shadow is part of ShadowHost's own visual, so it needs no receiver.
         ShadowHost sits behind the pill and stretches to its size; both slide and fade together, so
         the shadow tracks the pill. -->

    <UserControl.Resources>
        <Thickness x:Key="NoticePadding">11,7,13,8</Thickness>
        <Thickness x:Key="NoticeMargin">0,0,20,24</Thickness>
        <x:Double x:Key="NoticeFontSize">13</x:Double>
        <x:Double x:Key="NoticeGlyphSize">14</x:Double>
        <x:Double x:Key="NoticeSpacing">9</x:Double>
    </UserControl.Resources>

    <!-- Bottom-right of the editor area: out of the way of the caret, which is wherever the user was
         typing when the tab filled up. The right margin lines up with the editor's text inset. -->
    <Grid x:Name="NoticeRoot"
          HorizontalAlignment="Right"
          VerticalAlignment="Bottom"
          Margin="{StaticResource NoticeMargin}"
          Visibility="Collapsed"
          IsHitTestVisible="False">

        <!-- Empty, transparent, sized to the pill by the Grid stretch. Hosts the Composition drop
             shadow; declared first so the shadow paints behind the pill. -->
        <Border x:Name="ShadowHost" Opacity="0">
            <Border.RenderTransform>
                <TranslateTransform x:Name="ShadowSlide" />
            </Border.RenderTransform>
        </Border>

        <Border x:Name="NoticeHost"
                Padding="{StaticResource NoticePadding}"
                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{ThemeResource ControlCornerRadius}"
                Opacity="0"
                AutomationProperties.LiveSetting="Polite">
            <Border.RenderTransform>
                <TranslateTransform x:Name="NoticeSlide" />
            </Border.RenderTransform>
            <StackPanel Orientation="Horizontal" Spacing="{StaticResource NoticeSpacing}">
                <FontIcon x:Name="NoticeGlyph"
                          Glyph="&#xE7BA;"
                          FontSize="{StaticResource NoticeGlyphSize}"
                          Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                          VerticalAlignment="Center" />
                <TextBlock x:Name="NoticeText"
                           FontFamily="{ThemeResource ContentControlThemeFontFamily}"
                           FontSize="{StaticResource NoticeFontSize}"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="QuinSlate.Ui.Tray.TrayPeekPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:QuinSlate.Ui.Tray"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Storyboard x:Name="ShowStoryboard">
            <DoubleAnimation
                x:Name="GridAnimation"
                Storyboard.TargetName="GridTransform"
                Storyboard.TargetProperty="Y"
                From="12" To="0"
                Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <!-- No corner radius here: the hosting window owns the single rounded outline (see
         TrayPeekWindow's DWM corner preference). A second rounded border drawn by this panel
         would not align with the window's corners and would read as a detached edge. -->
    <Border
        x:Name="RootBorder"
        Background="{ThemeResource AppBackgroundGradient}">

        <!-- Resolution-independent layout: the header block (header + separator) is pinned to the
             top and the footer block (separator + footer) is pinned to the bottom. The middle
             buffer-list region is star-sized, so any few-pixel slack from DPI rounding or the DWM
             frame inset is absorbed there — spread evenly across the five buffer rows — and never
             pushes the footer past the bottom edge or the header off its top padding. This is why
             TrayPeekWindow's LogicalWindowHeight no longer needs to match the client height to the
             pixel. -->
        <Grid
            x:Name="RootGrid"
            Padding="0,6,0,6">

            <Grid.RenderTransform>
                <TranslateTransform x:Name="GridTransform" Y="0" />
            </Grid.RenderTransform>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header (pinned top) -->
            <Grid
                Grid.Row="0"
                Height="26">
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="8"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Padding="12, 0, 12, 0">
                    <Image
                        x:Name="HeaderIcon"
                        Source="ms-appx:///Assets/Square44x44Logo.scale-200.png"
                        Width="18"
                        Height="18"
                        VerticalAlignment="Center" />
                    <!-- TextLineBounds="Tight" trims the font's line box to the glyph bounds so
                         VerticalAlignment="Center" centres the visible letters rather than the
                         padded line box (whose asymmetric ascent/descent otherwise rides the text
                         above the logo). This replaces the old fixed pixel nudge and is
                         DPI-independent. -->
                    <TextBlock
                        x:Name="AppNameTextBlock"
                        FontSize="13"
                        FontWeight="SemiBold"
                        FontFamily="Segoe UI Variable Display"
                        VerticalAlignment="Center"
                        TextLineBounds="Tight"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                </StackPanel>
            </Grid>

            <!-- Header separator (part of the top-pinned block) -->
            <Grid
                Grid.Row="1"
                Height="12">
                <Border
                    Height="1"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                    VerticalAlignment="Center" />
            </Grid>

            <!-- Buffer-list region (star-sized: absorbs all DPI/frame slack). The five rows are
                 equal star heights so they stay evenly spaced while tolerating a few pixels of
                 variance in the region's total height. -->
            <Grid Grid.Row="2">

                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="65" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Row 0 -->
                <TextBlock
                    x:Name="Number0"
                    Grid.Row="0"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right"
                    Margin="0,1,0,0"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    FontSize="12"
                    FontFamily="Segoe UI Variable Text" />
                <TextBlock
                    x:Name="Emoji0"
                    Grid.Row="0"
                    Grid.Column="3"
                    FontSize="14"
                    FontFamily="Segoe UI Emoji"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right"
                    Margin="0,-3,0,0" />
                <TextBlock
                    x:Name="Title0"
                    Grid.Row="0"
                    Grid.Column="5"
                    VerticalAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    FontSize="13"
                    FontFamily="Segoe UI Variable Text"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <TextBlock
                    x:Name="Preview0"
                    Grid.Row="0"
                    Grid.Column="7"
                    VerticalAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    Padding="0, 0, 12, 0"
                    Margin="0,-1.5,0,0"
                    FontSize="13"
                    FontFamily="Cascadia Code"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                <!-- Row 1 -->
                <TextBlock
                    x:Name="Number1"
                    Grid.Row="1"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right"
                    Margin="0,1,0,0"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    FontSize="12"
                    FontFamily="Segoe UI Variable Text" />
                <TextBlock
                    x:Name="Emoji1"
                    Grid.Row="1"
                    Grid.Column="3"
                    FontSize="14"
                    FontFamily="Segoe UI Emoji"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right"
                    Margin="0,-3,0,0" />
                <TextBlock
                    x:Name="Title1"
                    Grid.Row="1"
                    Grid.Column="5"
                    VerticalAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    FontSize="13"
                    FontFamily="Segoe UI Variable Text"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <TextBlock
                    x:Name="Preview1"
                    Grid.Row="1"
                    Grid.Column="7"
                    VerticalAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    Padding="0, 0, 12, 0"
                    Margin="0,-1.5,0,0"
                    FontSize="13"
                    FontFamily="Cascadia Code"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                <!-- Row 2 -->
                <TextBlock
                    x:Name="Number2"
                    Grid.Row="2"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right"
                    Margin="0,1,0,0"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    FontSize="12"
                    FontFamily="Segoe UI Variable Text" />
                <TextBlock
                    x:Name="Emoji2"
                    Grid.Row="2"
                    Grid.Column="3"
                    FontSize="14"
                    FontFamily="Segoe UI Emoji"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right"
                    Margin="0,-3,0,0" />
                <TextBlock
                    x:Name="Title2"
                    Grid.Row="2"
                    Grid.Column="5"
                    VerticalAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    FontSize="13"
                    FontFamily="Segoe UI Variable Text"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <TextBlock
                    x:Name="Preview2"
                    Grid.Row="2"
                    Grid.Column="7"
                    VerticalAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    Padding="0, 0, 12, 0"
                    Margin="0,-1.5,0,0"
                    FontSize="13"
                    FontFamily="Cascadia Code"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                <!-- Row 3 -->
                <TextBlock
                    x:Name="Number3"
                    Grid.Row="3"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right"
                    Margin="0,1,0,0"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    FontSize="12"
                    FontFamily="Segoe UI Variable Text" />
                <TextBlock
                    x:Name="Emoji3"
                    Grid.Row="3"
                    Grid.Column="3"
                    FontSize="14"
                    FontFamily="Segoe UI Emoji"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right"
                    Margin="0,-3,0,0" />
                <TextBlock
                    x:Name="Title3"
                    Grid.Row="3"
                    Grid.Column="5"
                    VerticalAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    FontSize="13"
                    FontFamily="Segoe UI Variable Text"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <TextBlock
                    x:Name="Preview3"
                    Grid.Row="3"
                    Grid.Column="7"
                    VerticalAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    Padding="0, 0, 12, 0"
                    Margin="0,-1.5,0,0"
                    FontSize="13"
                    FontFamily="Cascadia Code"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                <!-- Row 4 -->
                <TextBlock
                    x:Name="Number4"
                    Grid.Row="4"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right"
                    Margin="0,1,0,0"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    FontSize="12"
                    FontFamily="Segoe UI Variable Text" />
                <TextBlock
                    x:Name="Emoji4"
                    Grid.Row="4"
                    Grid.Column="3"
                    FontSize="14"
                    FontFamily="Segoe UI Emoji"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right"
                    Margin="0,-3,0,0" />
                <TextBlock
                    x:Name="Title4"
                    Grid.Row="4"
                    Grid.Column="5"
                    VerticalAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    FontSize="13"
                    FontFamily="Segoe UI Variable Text"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <TextBlock
                    x:Name="Preview4"
                    Grid.Row="4"
                    Grid.Column="7"
                    VerticalAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    Padding="0, 0, 12, 0"
                    Margin="0,-1.5,0,0"
                    FontSize="13"
                    FontFamily="Cascadia Code"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

            </Grid>

            <!-- Footer separator (part of the bottom-pinned block) -->
            <Grid
                Grid.Row="3"
                Height="12">
                <Border
                    Height="1"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                    VerticalAlignment="Center" />
            </Grid>

            <!-- Footer (pinned bottom). Vertical placement comes from the fixed-height row and
                 VerticalAlignment="Center"; the small negative top margins are glyph-baseline
                 nudges only and no longer compensate for a mis-sized row. -->
            <Grid
                Grid.Row="4"
                Height="26"
                Padding="12, 0, 8, 0">
                <TextBlock
                    Text="Press to open"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    FontSize="11"
                    FontFamily="Segoe UI Variable Text"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}" />

                <StackPanel
                    Orientation="Horizontal"
                    Spacing="4"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">

                    <Border
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Height="18"
                        Padding="6,0,6,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            Text="Ctrl"
                            FontSize="10"
                            FontFamily="Segoe UI Variable Text"
                            TextLineBounds="Tight"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Border>

                    <Border
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Height="18"
                        Padding="6,0,6,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            Text="Shift"
                            FontSize="10"
                            FontFamily="Segoe UI Variable Text"
                            TextLineBounds="Tight"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Border>

                    <Border
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Height="18"
                        Padding="6,0,6,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            Text="Q"
                            FontSize="10"
                            FontFamily="Segoe UI Variable Text"
                            TextLineBounds="Tight"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Border>

                </StackPanel>
            </Grid>

        </Grid>
    </Border>
</UserControl>

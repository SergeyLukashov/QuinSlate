<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="QuinSlate.Ui.Views.BufferPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:QuinSlate.Ui.Views"
    xmlns:components="using:QuinSlate.Ui.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Themes/BufferPanelResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Background="{ThemeResource AppBackgroundGradient}">
        <!-- Tabs reorder by drag inside the strip only. The SDK maps CanReorderTabs ->
             ListView.CanReorderItems and AllowDropTabs -> ListView.AllowDrop, and an in-list
             reorder needs both; CanDragTabs -> ListView.CanDragItems governs dragging a tab OUT
             as a data payload, which QuinSlate has no target for (the five buffers are fixed), so
             it stays off and no drag visual ever leaves the window. -->
        <TabView
            x:Name="BufferTabView"
            IsAddTabButtonVisible="False"
            CanReorderTabs="True"
            CanDragTabs="False"
            AllowDropTabs="True"
            TabWidthMode="SizeToContent"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch"
            Padding="{StaticResource TabViewTabStripRightPadding}"
            Margin="0,-1,0,0"
            BorderBrush="Transparent"
            BorderThickness="0">

            <TabView.Resources>
                <Thickness x:Key="TabViewBorderThickness">0</Thickness>
                <SolidColorBrush x:Key="TabViewBorderBrush" Color="Transparent" />
                <SolidColorBrush x:Key="TabViewItemSeparatorBrush" Color="Transparent" />

                <!-- Tab sizing is entirely ours; TabWidthMode is SizeToContent, NOT Equal.

                     Equal mode never did what the name suggests here: it does not shrink tabs to
                     a star column. The tab items live inside a horizontally scrollable
                     ScrollViewer, so each item is measured against its MaxWidth, not against
                     (window - footer) — a large static MaxWidth makes every tab measure near
                     MaxWidth, so the strip overflows and clips off the right edge (the overflow
                     bug a static MaxWidth=1000 produced). Equal tabs therefore have always come
                     from code-behind (UpdateEqualTabMaxWidth) sizing each tab's HEADER to
                     available/count on every size change.

                     Equal mode additionally stamps an explicit Width on every TabViewItem from
                     its own UpdateTabWidths, which it re-runs on every TabItems change. A
                     drag-reorder lifts the dragged tab out of the collection and puts it back a
                     frame later, and the width it computes during that gap clamps to
                     minTabWidth — so all five tabs visibly snapped narrow for the duration of
                     every drag and sprang back on drop. SizeToContent leaves Width unset, so the
                     tabs simply take their pinned header width and hold it across the drag.

                     These two stay as static bounds: MinWidth is the 100px floor that
                     TabStripCalculator enforces (below it the tabs stop shrinking, the strip
                     overflows, and the SDK surfaces its scroll buttons), and MaxWidth is a
                     non-binding ceiling kept well above any realistic per-tab share so it never
                     caps the tabs on a wide window (the SDK's own default is 200). -->
                <x:Double x:Key="TabViewItemMinWidth">100</x:Double>
                <x:Double x:Key="TabViewItemMaxWidth">1000</x:Double>

                <!-- Compact scroll buttons styling -->
                <x:Double x:Key="TabViewItemScrollButtonWidth">20</x:Double>
                <x:Double x:Key="TabViewItemScrollButonFontSize">8</x:Double>
                <Thickness x:Key="TabViewItemLeftScrollButtonContainerPadding">0,0,0,3</Thickness>
                <Thickness x:Key="TabViewItemRightScrollButtonContainerPadding">0,0,0,3</Thickness>

                <Style x:Key="TabViewScrollButtonStyle" TargetType="RepeatButton">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="{ThemeResource TabViewScrollButtonForeground}" />
                    <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
                    <Setter Property="FontSize" Value="{ThemeResource TabViewItemScrollButonFontSize}" />
                    <Setter Property="FontFamily" Value="{ThemeResource SymbolThemeFontFamily}" />
                    <Setter Property="Width" Value="{ThemeResource TabViewItemScrollButtonWidth}" />
                    <Setter Property="Height" Value="{ThemeResource TabViewItemScrollButtonHeight}" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="FocusVisualMargin" Value="-3" />
                    <Setter Property="ManipulationMode" Value="None" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="RepeatButton">
                                <ContentPresenter x:Name="ContentPresenter"
                                                  Background="{TemplateBinding Background}"
                                                  BorderBrush="{TemplateBinding BorderBrush}"
                                                  BorderThickness="{TemplateBinding BorderThickness}"
                                                  BackgroundSizing="{TemplateBinding BackgroundSizing}"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  ContentTransitions="{TemplateBinding ContentTransitions}"
                                                  CornerRadius="{TemplateBinding CornerRadius}"
                                                  FontSize="{TemplateBinding FontSize}"
                                                  FontFamily="{TemplateBinding FontFamily}"
                                                  FontWeight="{TemplateBinding FontWeight}"
                                                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  AutomationProperties.AccessibilityView="Raw"
                                                  Opacity="0.6">
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal" />
                                            <VisualState x:Name="PointerOver">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="ContentPresenter"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="1.0"
                                                                     Duration="0:0:0.1" />
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Background">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent" />
                                                    </ObjectAnimationUsingKeyFrames>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="BorderBrush">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent" />
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </VisualState>
                                            <VisualState x:Name="Pressed">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="ContentPresenter"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="0.8"
                                                                     Duration="0:0:0.1" />
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Background">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent" />
                                                    </ObjectAnimationUsingKeyFrames>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="BorderBrush">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent" />
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </VisualState>
                                            <VisualState x:Name="Disabled">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="ContentPresenter"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="0.3"
                                                                     Duration="0:0:0.1" />
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Background">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent" />
                                                    </ObjectAnimationUsingKeyFrames>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="BorderBrush">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent" />
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                </ContentPresenter>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <!-- Modern WinUI tooltip shared by the pin and close buttons -->
                <Style TargetType="ToolTip">
                    <Setter Property="Background" Value="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" />
                    <Setter Property="BorderBrush" Value="{ThemeResource SystemControlTransientBorderBrush}" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="CornerRadius" Value="4" />
                    <Setter Property="Padding" Value="8,5,8,5" />
                    <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                    <Setter Property="FontSize" Value="12" />
                    <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
                </Style>
            </TabView.Resources>

            <TabView.TabStripHeader>
                <Border
                    x:Name="TitleBarIconDragArea"
                    Padding="9,3,6,0"
                    MinHeight="{StaticResource TitleBarRowHeight}"
                    VerticalAlignment="Stretch"
                    Background="Transparent">
                    <Image
                        x:Name="TitleBarIconImage"
                        Source="ms-appx:///Assets/Square44x44Logo.scale-200.png"
                        Width="20"
                        Height="20"
                        VerticalAlignment="Center" />
                </Border>
            </TabView.TabStripHeader>

            <!-- Fixed-width transparent spacer reserving exactly the overlay button cluster's
                 width (TitleBarButtonsClusterWidth = 92) in the tab strip, and the ONLY place
                 that width is reserved (the TabView's right Padding is 0 to avoid stacking — see
                 the TabViewTabStripRightPadding note above). A fixed footer width makes the SDK
                 pin RightContentColumn.MinWidth to a stable 92 (no star-column collapse, the
                 defect of the earlier footer-hosted approach), so the tabs stop where the
                 buttons begin and never slide under them. The spacer is IsHitTestVisible=False
                 so it never blocks the overlay buttons drawn over it; the drag region (set in
                 MainWindow via SetTitleBar(TitleBarIconDragArea)) covers only the LEFT icon
                 area. -->
            <TabView.TabStripFooter>
                <Border
                    x:Name="TitleBarFooterSpacer"
                    Width="{StaticResource TitleBarButtonsClusterWidth}"
                    Height="{StaticResource TitleBarRowHeight}"
                    Background="Transparent"
                    IsHitTestVisible="False" />
            </TabView.TabStripFooter>
        </TabView>

        <!-- The single WebView2 that hosts CodeMirror 6 for all five buffers. It is a top-level
             overlay positioned by code (PositionEditorHost) to cover exactly the TabView's content
             presenter, so the tab strip stays interactive above it. It is never reparented — the
             page swaps the active buffer's CM6 state internally on tab switch — so Chromium is
             created once and kept alive. EditorHostContent carries the entrance-animation transform;
             the WebView paints its own dithered-gradient background so the layer needs no fill. -->
        <Grid x:Name="EditorHostLayer"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Grid x:Name="EditorHostContent">
                <!-- The editor's inset from every side is a margin on the WebView2, not padding on
                     the CodeMirror content. Padding lives inside the scrolled region, so a top
                     padding scrolls away and text rides up to the tabs; a margin is fixed chrome the
                     window gradient shows through. Top is 14 (the retired 4px container margin +
                     10px editor top padding); the others target the retired 16px editor padding.
                     Right is 16 - 12 = 4: the page reserves a 12px scrollbar gutter unconditionally
                     (scrollbar-gutter: stable), so the scrollbar sits inside the 16px gap and the
                     text inset stays 16 whether or not the buffer scrolls. See editor.css. -->
                <WebView2 x:Name="EditorWebView"
                          Margin="16,14,4,16"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" />
                <!-- Flat mid-tone cover shown ON TOP of the WebView2 at startup so the black
                     Chromium swapchain (before its first painted frame) is never visible. Dropped
                     once the page reports it has painted the gradient + text; mid-tone -> mesh is
                     imperceptible. IsHitTestVisible=False so it never blocks input if it lingers.
                     Must track the WebView2's margin exactly, or the swapchain peeks out. -->
                <Border x:Name="EditorStartupCover"
                        Margin="16,14,4,16"
                        IsHitTestVisible="False"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch" />
            </Grid>

            <!-- Transient "this tab is full" notice, shown when an edit is clamped at the character
                 cap. Declared after EditorHostContent so it paints over the WebView2 (the same
                 overlay trick as EditorStartupCover); the control itself is non-interactive. -->
            <components:LimitNoticeView x:Name="LimitNoticeSurface" />
        </Grid>

        <!-- Pin and close buttons as a top-level OVERLAY anchored to the window's top-right
             corner. Being top-level (not inside any TabView column) they can never be clipped,
             unlike the two earlier footer-hosted attempts. The cluster occupies exactly
             TitleBarButtonsClusterWidth and lines up over the footer spacer: the pin's left
             gap (TitleBarFooterLeftGap) sits 12px past the tabs' right edge, and the close
             button sits flush against the window's right edge (no right inset). -->
        <StackPanel
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Height="{StaticResource TitleBarRowHeight}">
            <Button
                x:Name="PinButton"
                Style="{StaticResource TitleBarButtonStyle}"
                Margin="{StaticResource TitleBarFooterLeftGap}"
                ToolTipService.ToolTip="Keep window always on top"
                IsTabStop="False"
                UseSystemFocusVisuals="False"
                Click="OnPinButtonClicked">
                <FontIcon
                    x:Name="PinIcon"
                    Glyph="&#xE718;"
                    FontSize="12" />
            </Button>
            <Button
                x:Name="CloseButton"
                Style="{StaticResource CloseTitleBarButtonStyle}"
                Margin="0"
                ToolTipService.ToolTip="Close"
                IsTabStop="False"
                UseSystemFocusVisuals="False"
                Click="OnCloseButtonClicked">
                <FontIcon
                    Glyph="&#xE8BB;"
                    FontSize="9" />
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
